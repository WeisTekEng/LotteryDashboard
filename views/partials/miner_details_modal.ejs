<!-- Miner Details Modal (Charts & Heatmap) -->
<div id="minerDetailsModal" class="modal-overlay">
    <div class="modal-content modal-responsive-container">
        <div class="modal-header">
            <div class="modal-toolbar">
                <span class="modal-title" id="minerDetailsTitle">AATE Miner Details</span>
                <span
                    style="font-size: 0.75rem; color: #10b981; background: rgba(16, 185, 129, 0.1); padding: 2px 8px; border-radius: 12px; border: 1px solid rgba(16, 185, 129, 0.2);">
                    Auto-refresh: <span id="details-refresh-timer">3</span>s
                </span>
                <button onclick="exportTuningLog()" class="btn-sm"
                    style="background: rgba(59, 130, 246, 0.2); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.4); border-radius: 4px; padding: 2px 8px; font-size: 0.75rem; cursor: pointer;">
                    Export Tuning Log CSV
                </button>
                <button onclick="exportGridHistory()" class="btn-sm"
                    style="background: rgba(59, 130, 246, 0.2); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.4); border-radius: 4px; padding: 2px 8px; font-size: 0.75rem; cursor: pointer;">
                    Export Heatmap History CSV
                </button>
            </div>
            <button class="modal-close" onclick="closeMinerDetailsModal()">×</button>
        </div>
        <div class="modal-body" style="padding: 0; flex: 1; display: flex; flex-direction: column; overflow: hidden;">
            <!-- Tabs -->
            <div class="modal-tabs">
                <button onclick="switchDetailsTab('performance')" class="modal-tab-btn active" id="tab-btn-performance">
                    Performance Graphs
                </button>
                <button onclick="switchDetailsTab('heatmap')" class="modal-tab-btn" id="tab-btn-heatmap">
                    Stability Scatter Plot
                </button>
                <button onclick="switchDetailsTab('grid')" class="modal-tab-btn" id="tab-btn-grid">
                    Hashrate Map
                </button>
                <button onclick="switchDetailsTab('efficiency_grid')" class="modal-tab-btn"
                    id="tab-btn-efficiency_grid">
                    Efficiency Map
                </button>
                <button onclick="switchDetailsTab('temp_grid')" class="modal-tab-btn" id="tab-btn-temp_grid">
                    Temp Map
                </button>
                <button onclick="switchDetailsTab('faults')" class="modal-tab-btn" id="tab-btn-faults">
                    Fault Analysis
                </button>
                <button onclick="switchDetailsTab('history')" class="modal-tab-btn" id="tab-btn-history">
                    Log History
                </button>
            </div>

            <div style="padding: 1.5rem; flex: 1; overflow-y: auto;">
                <!-- Performance Tab -->
                <div id="tab-performance" class="details-tab">
                    <div style="margin-bottom: 2rem;">
                        <h4 style="margin: 0 0 1rem 0; color: #94a3b8; font-size: 0.9rem;">Hashrate & Efficiency</h4>
                        <div class="chart-container-sm">
                            <canvas id="detailsChartHash"></canvas>
                        </div>
                    </div>
                    <div>
                        <h4 style="margin: 0 0 1rem 0; color: #94a3b8; font-size: 0.9rem;">Voltage & Frequency</h4>
                        <div class="chart-container-sm">
                            <canvas id="detailsChartTune"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Heatmap Tab -->
                <div id="tab-heatmap" class="details-tab" style="display: none;">
                    <p style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 1rem;">
                        Scatter plot of attempted settings. <span style="color: #10b981;">Green = Stable</span>, <span
                            style="color: #ef4444;">Red = Fault/Error</span>.
                    </p>
                    <div class="chart-container-lg">
                        <canvas id="detailsChartHeatmap"></canvas>
                    </div>
                </div>

                <!-- Grid Tab (Porformance heatmap) -->
                <div id="tab-grid" class="details-tab" style="display: none;">
                    <p style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 1rem;">
                        Performance Grid. X-Axis: Voltage, Y-Axis: Frequency. Color: Hashrate (<span
                            style="color: #ef4444;">Low</span> to <span style="color: #10b981;">High</span>).
                    </p>
                    <div class="chart-container-xl">
                        <h4 style="margin: 0 0 0.5rem 0; color: #94a3b8; font-size: 0.9rem; text-align: center;">
                            Hashrate (GH/s)</h4>
                        <canvas id="detailsChartGrid"></canvas>
                    </div>
                </div>

                <!-- Grid Tab (Efficiency heatmap) -->
                <div id="tab-efficiency_grid" class="details-tab" style="display: none;">
                    <p style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 1rem;">
                        Efficiency Grid. Color: J/TH (<span style="color: #10b981;">Low/Efficient</span> to <span
                            style="color: #ef4444;">High/Inefficient</span>).
                    </p>
                    <div class="chart-container-xl">
                        <h4 style="margin: 0 0 0.5rem 0; color: #94a3b8; font-size: 0.9rem; text-align: center;">
                            Efficiency (J/TH)</h4>
                        <canvas id="detailsChartEfficiencyGrid"></canvas>
                    </div>
                </div>

                <!-- Grid Tab (Temperature heatmap) -->
                <div id="tab-temp_grid" class="details-tab" style="display: none;">
                    <p style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 1rem;">
                        Temperature Grid. Color: °C (<span style="color: #10b981;">Low/Cool</span> to <span
                            style="color: #ef4444;">High/Hot</span>).
                    </p>
                    <div class="chart-container-xl">
                        <h4 style="margin: 0 0 0.5rem 0; color: #94a3b8; font-size: 0.9rem; text-align: center;">
                            Temperature (°C)</h4>
                        <canvas id="detailsChartTempGrid"></canvas>
                    </div>
                </div>

                <!-- Fault Analysis Tab -->
                <div id="tab-faults" class="details-tab" style="display: none;">
                    <div style="overflow-x: auto;">
                        <table
                            style="width: 100%; font-size: 0.8rem; border-collapse: collapse; color: #cbd5e1; min-width: 500px;">
                            <thead>
                                <tr style="text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">
                                    <th style="padding: 8px;">Time</th>
                                    <th style="padding: 8px;">Reason</th>
                                    <th style="padding: 8px;">Volt</th>
                                    <th style="padding: 8px;">Freq</th>
                                    <th style="padding: 8px;">Power</th>
                                    <th style="padding: 8px;">Hash</th>
                                    <th style="padding: 8px;">Vin</th>
                                    <th style="padding: 8px;">J/TH</th>
                                    <th style="padding: 8px;">Core Temp</th>
                                    <th style="padding: 8px;">Vrm Temp</th>
                                    <th style="padding: 8px;">Error Rate</th>
                                    <th style="padding: 8px;">New Limits?</th>
                                </tr>
                            </thead>
                            <tbody id="detailsFaultTable">
                                <!-- Populated by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- History Tab -->
                <div id="tab-history" class="details-tab" style="display: none;">
                    <div style="overflow-x: auto;">
                        <table
                            style="width: 100%; font-size: 0.8rem; border-collapse: collapse; color: #cbd5e1; min-width: 500px;">
                            <thead>
                                <tr style="text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">
                                    <th style="padding: 8px;">Time</th>
                                    <th style="padding: 8px;">Action</th>
                                    <th style="padding: 8px;">Volt</th>
                                    <th style="padding: 8px;">Freq</th>
                                    <th style="padding: 8px;">Power</th>
                                    <th style="padding: 8px;">Hash</th>
                                    <th style="padding: 8px;">Vin</th>
                                    <th style="padding: 8px;">J/TH</th>
                                    <th style="padding: 8px;">Core Temp</th>
                                    <th style="padding: 8px;">Vrm Temp</th>
                                    <th style="padding: 8px;">Error Rate</th>
                                </tr>
                            </thead>
                            <tbody id="detailsHistoryTable">
                                <!-- Populated by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>