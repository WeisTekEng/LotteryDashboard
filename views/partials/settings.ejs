<section id="settings-view" style="display: none; margin-bottom: 2rem;">
    <div
        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; position: sticky; top: 0; background: #0f172a; padding: 1rem 0; z-index: 10; border-bottom: 1px solid rgba(255,255,255,0.05);">
        <div>
            <h2 style="font-size: 1.5rem; font-weight: 700; color: white; margin: 0;">Dashboard Settings</h2>
            <p style="color: #94a3b8; font-size: 0.875rem; margin: 0;">Global limits, ports, and Auto-Tune
                profiles</p>
        </div>
        <button onclick="saveGlobalConfig()" class="btn-primary" style="padding: 0.75rem 1.5rem; font-size: 1rem;">Save
            All Settings</button>
    </div>

    <!-- Settings Tabs -->
    <div class="modal-tabs"
        style="margin-bottom: 1.5rem; background: transparent; border-bottom: 1px solid rgba(255,255,255,0.1);">
        <button onclick="switchSettingsTab('network')" class="modal-tab-btn active" id="btn-settings-network">
            Network & Ports
        </button>
        <button onclick="switchSettingsTab('limits')" class="modal-tab-btn" id="btn-settings-limits">
            Performance Limits
        </button>
        <button onclick="switchSettingsTab('autotune')" class="modal-tab-btn" id="btn-settings-autotune">
            Auto-Tune Profiles
        </button>
    </div>

    <!-- Tab Contents -->
    <div id="settings-tab-network" class="settings-tab-content">
        <div id="config-container-network" class="grid"
            style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));"></div>
    </div>

    <div id="settings-tab-limits" class="settings-tab-content" style="display: none;">
        <div id="config-container-limits" class="grid"
            style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));"></div>
    </div>

    <div id="settings-tab-autotune" class="settings-tab-content" style="display: none;">
        <div id="config-container-autotune" class="grid"
            style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));"></div>
    </div>
</section>